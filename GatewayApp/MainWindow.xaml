<Window x:Class="GatewayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GatewayApp.Converters"
        xmlns:models="clr-namespace:GatewayApp.Models"
        Title="{Binding WindowTitle}"
        Icon="Assets/AppIcon.ico"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Closing="Window_Closing">
    <Window.Resources>
        <conv:LedStateConverter x:Key="LedStateConverter" />
        <conv:LedStrokeConverter x:Key="LedStrokeConverter" />
        <conv:LedStrokeThicknessConverter x:Key="LedStrokeThicknessConverter" />
        <conv:EntryValueBrushConverter x:Key="EntryValueBrushConverter" />
        <conv:BoolVisibilityConverter x:Key="BoolVisibilityConverter" />
        <conv:StringVisibilityConverter x:Key="StringVisibilityConverter" />
        <conv:NullVisibilityConverter x:Key="NullVisibilityConverter" />
        <conv:DisplayTypeTextConverter x:Key="DisplayTypeTextConverter" />

        <Style x:Key="MonitorCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MonitorMonoText" TargetType="TextBlock" BasedOn="{StaticResource MonitorCellText}">
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="12,0" />
        </Style>

        <Style x:Key="MonitorValueButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="#1f1f1f" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="#111111" />
                    <Setter Property="Background" Value="#c8c8c8" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Foreground" Value="#111111" />
                    <Setter Property="Background" Value="#c8c8c8" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#777" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Background="#484848">
        <Menu DockPanel.Dock="Top" Background="#d8d8d8" Foreground="#1f1f1f">
            <MenuItem Header="{DynamicResource MenuFile}">
                <MenuItem Header="{DynamicResource MenuImportCsv}" Click="ImportCsv_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuLoadSettings}" Click="LoadSettings_Click" />
                <MenuItem Header="{DynamicResource MenuSave}" Click="SaveSettings_Click" />
                <MenuItem Header="{DynamicResource MenuSaveAs}" Click="SaveSettingsAs_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuExit}" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuCommunication}">
                <MenuItem Header="{DynamicResource MenuPlcSettings}" Click="PlcSettings_Click" />
                <MenuItem Header="{DynamicResource MenuModbusSettings}" Click="ModbusSettings_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuTools}">
                <MenuItem Header="{DynamicResource MenuBulkAssign}" Click="BulkAssign_Click" />
                <MenuItem Header="{DynamicResource MenuShowLog}" Click="ShowLog_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuLanguage}">
                <MenuItem x:Name="EnglishLanguageMenuItem"
                          Header="{DynamicResource LanguageEnglish}"
                          IsCheckable="True"
                          Click="LanguageEnglish_Click" />
                <MenuItem x:Name="JapaneseLanguageMenuItem"
                          Header="{DynamicResource LanguageJapanese}"
                          IsCheckable="True"
                          Click="LanguageJapanese_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuHelp}">
                <MenuItem Header="{DynamicResource MenuAbout}" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Height="38" Background="#303030">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,18,0">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Fill" Value="#3edc3e" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding GatewayStatus}" Foreground="#f0f0f0" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding StartStopText}"
                    Command="{Binding ToggleRunningCommand}"
                    Padding="12,2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Content="{Binding ForceXText}"
                              Command="{Binding ToggleForceXCommand}"
                              IsChecked="{Binding IsForceXEnabled, Mode=OneWay}"
                              Padding="12,2"
                              Margin="0,0,6,0">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Foreground" Value="#777" />
                            <Setter Property="Background" Value="#2a2a2a" />
                            <Setter Property="BorderBrush" Value="#555" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="#ff8c00" />
                                    <Setter Property="BorderBrush" Value="#ff8c00" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <ToggleButton Content="{Binding ForceYText}"
                              Command="{Binding ToggleForceYCommand}"
                              IsChecked="{Binding IsForceYEnabled, Mode=OneWay}"
                              Padding="12,2">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Foreground" Value="#777" />
                            <Setter Property="Background" Value="#2a2a2a" />
                            <Setter Property="BorderBrush" Value="#555" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="#ff8c00" />
                                    <Setter Property="BorderBrush" Value="#ff8c00" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <StatusBar DockPanel.Dock="Bottom" Background="#222" Foreground="#b0b0b0">
            <TextBlock Text="{Binding ModbusStatus}" />
            <Separator />
            <TextBlock Text="{Binding ModbusClientText}" />
            <Separator />
            <TextBlock Text="{Binding PlcStatus}" />
        </StatusBar>

        <TabControl Background="#484848" BorderThickness="0">
            <TabItem Header="Monitor">
                <ScrollViewer Background="#484848" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid Grid.IsSharedSizeScope="True" HorizontalAlignment="Center" Margin="12,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Modbus TCP/IP Client"
                                   Foreground="#ffffff"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />

                        <Grid Grid.Row="1" Height="32" Background="#2a2a2a">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="150" SharedSizeGroup="MonitorLeftComment" />
                                <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorLeftPlc" />
                                <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorLeftModbus" />
                                <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorLeftValue" />
                                <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorRightValue" />
                                <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorRightModbus" />
                                <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorRightPlc" />
                                <ColumnDefinition Width="Auto" MinWidth="170" SharedSizeGroup="MonitorRightComment" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="S E N S O R S" Foreground="#ffffff" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0" />
                            <TextBlock Grid.Column="1" Text="PLC(X)" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="2" Text="Coil" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="5" Text="Input" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="6" Text="PLC(Y)" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="7" Text="A C T U A T O R S" Foreground="#ffffff" FontSize="13" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                        </Grid>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding BoolRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="150" SharedSizeGroup="MonitorLeftComment" />
                                            <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorLeftPlc" />
                                            <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorLeftModbus" />
                                            <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorLeftValue" />
                                            <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorRightValue" />
                                            <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorRightModbus" />
                                            <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorRightPlc" />
                                            <ColumnDefinition Width="Auto" MinWidth="170" SharedSizeGroup="MonitorRightComment" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Left.Comment}" Style="{StaticResource MonitorCellText}" Margin="8,0,18,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Left.PlcAddress}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Left.ModbusLabel}" Style="{StaticResource MonitorMonoText}" />
                                        <Border Grid.Column="3"
                                                Width="10"
                                                Height="18"
                                                HorizontalAlignment="Center"
                                                Tag="{Binding Left}"
                                                Cursor="Hand"
                                                Background="{Binding Left.LedState, Converter={StaticResource LedStateConverter}}"
                                                BorderBrush="{Binding Left.LedState, Converter={StaticResource LedStrokeConverter}}"
                                                BorderThickness="{Binding Left.LedState, Converter={StaticResource LedStrokeThicknessConverter}}"
                                                Visibility="{Binding Left, Converter={StaticResource NullVisibilityConverter}}"
                                                MouseLeftButtonDown="Led_MouseLeftButtonDown" />
                                        <Border Grid.Column="4"
                                                Width="10"
                                                Height="18"
                                                HorizontalAlignment="Center"
                                                Tag="{Binding Right}"
                                                Cursor="Hand"
                                                Background="{Binding Right.LedState, Converter={StaticResource LedStateConverter}}"
                                                BorderBrush="{Binding Right.LedState, Converter={StaticResource LedStrokeConverter}}"
                                                BorderThickness="{Binding Right.LedState, Converter={StaticResource LedStrokeThicknessConverter}}"
                                                Visibility="{Binding Right, Converter={StaticResource NullVisibilityConverter}}"
                                                MouseLeftButtonDown="Led_MouseLeftButtonDown" />
                                        <TextBlock Grid.Column="5" Text="{Binding Right.ModbusLabel}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="6" Text="{Binding Right.PlcAddress}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="7" Text="{Binding Right.Comment}" Style="{StaticResource MonitorCellText}" TextAlignment="Right" Margin="18,0,8,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="3" Height="1" Background="#5a5a5a" Margin="0,2" />

                        <Grid Grid.Row="4" Height="32" Background="#2a2a2a">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="150" SharedSizeGroup="MonitorLeftComment" />
                                <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorLeftPlc" />
                                <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorLeftModbus" />
                                <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorLeftValue" />
                                <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorRightValue" />
                                <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorRightModbus" />
                                <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorRightPlc" />
                                <ColumnDefinition Width="Auto" MinWidth="170" SharedSizeGroup="MonitorRightComment" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="S E N S O R S" Foreground="#ffffff" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0" />
                            <TextBlock Grid.Column="1" Text="PLC(X)" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="2" Text="Holding Reg" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="5" Text="Input Reg" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="6" Text="PLC(Y)" Style="{StaticResource MonitorMonoText}" Foreground="#ffffff" />
                            <TextBlock Grid.Column="7" Text="A C T U A T O R S" Foreground="#ffffff" FontSize="13" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                        </Grid>

                        <ItemsControl Grid.Row="5" ItemsSource="{Binding RegisterRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="150" SharedSizeGroup="MonitorLeftComment" />
                                            <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorLeftPlc" />
                                            <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorLeftModbus" />
                                            <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorLeftValue" />
                                            <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="MonitorRightValue" />
                                            <ColumnDefinition Width="Auto" MinWidth="116" SharedSizeGroup="MonitorRightModbus" />
                                            <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="MonitorRightPlc" />
                                            <ColumnDefinition Width="Auto" MinWidth="170" SharedSizeGroup="MonitorRightComment" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Left.Comment}" Style="{StaticResource MonitorCellText}" Margin="8,0,18,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Left.PlcAddress}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Left.ModbusLabel}" Style="{StaticResource MonitorMonoText}" />
                                        <Grid Grid.Column="3" Visibility="{Binding Left, Converter={StaticResource NullVisibilityConverter}}">
                                            <Button Content="{Binding Left.DisplayValue}"
                                                    Tag="{Binding Left}"
                                                    Style="{StaticResource MonitorValueButton}"
                                                    Foreground="{Binding Left.IsForceApplied, Converter={StaticResource EntryValueBrushConverter}}"
                                                    ToolTip="{Binding Left.RegisterIntegerToolTip}"
                                                    Visibility="{Binding Left.IsForceEditing, Converter={StaticResource BoolVisibilityConverter}, ConverterParameter=Invert}"
                                                    Click="RegisterValue_Click" />
                                            <TextBox Text="{Binding Left.ForceEditText, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="{Binding Left}"
                                                     Width="88"
                                                     FontFamily="Consolas"
                                                     FontSize="14"
                                                     Padding="1,0"
                                                     HorizontalContentAlignment="Center"
                                                     Background="#1a1a1a"
                                                     Foreground="#ff8c00"
                                                     BorderBrush="#ff8c00"
                                                     Visibility="{Binding Left.IsForceEditing, Converter={StaticResource BoolVisibilityConverter}}"
                                                     KeyDown="RegisterForceTextBox_KeyDown"
                                                     LostFocus="RegisterForceTextBox_LostFocus"
                                                     IsVisibleChanged="RegisterForceTextBox_IsVisibleChanged" />
                                        </Grid>
                                        <Grid Grid.Column="4" Visibility="{Binding Right, Converter={StaticResource NullVisibilityConverter}}">
                                            <Button Content="{Binding Right.DisplayValue}"
                                                    Tag="{Binding Right}"
                                                    Style="{StaticResource MonitorValueButton}"
                                                    Foreground="{Binding Right.IsForceApplied, Converter={StaticResource EntryValueBrushConverter}}"
                                                    ToolTip="{Binding Right.RegisterIntegerToolTip}"
                                                    Visibility="{Binding Right.IsForceEditing, Converter={StaticResource BoolVisibilityConverter}, ConverterParameter=Invert}"
                                                    Click="RegisterValue_Click" />
                                            <TextBox Text="{Binding Right.ForceEditText, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="{Binding Right}"
                                                     Width="88"
                                                     FontFamily="Consolas"
                                                     FontSize="14"
                                                     Padding="1,0"
                                                     HorizontalContentAlignment="Center"
                                                     Background="#1a1a1a"
                                                     Foreground="#ff8c00"
                                                     BorderBrush="#ff8c00"
                                                     Visibility="{Binding Right.IsForceEditing, Converter={StaticResource BoolVisibilityConverter}}"
                                                     KeyDown="RegisterForceTextBox_KeyDown"
                                                     LostFocus="RegisterForceTextBox_LostFocus"
                                                     IsVisibleChanged="RegisterForceTextBox_IsVisibleChanged" />
                                        </Grid>
                                        <TextBlock Grid.Column="5" Text="{Binding Right.ModbusLabel}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="6" Text="{Binding Right.PlcAddress}" Style="{StaticResource MonitorMonoText}" />
                                        <TextBlock Grid.Column="7" Text="{Binding Right.Comment}" Style="{StaticResource MonitorCellText}" TextAlignment="Right" Margin="18,0,8,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Mapping">
                <Grid Background="#ebebeb" Margin="0">
                    <DataGrid x:Name="MappingGrid"
                              ItemsSource="{Binding Mappings}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              Margin="12"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Sorting="MappingGrid_Sorting">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColumnModbusType}" Binding="{Binding ModbusType}" SortMemberPath="ModbusType" IsReadOnly="True" Width="120" />
                            <DataGridTextColumn Header="{DynamicResource ColumnModbusAddress}" Binding="{Binding ModbusAddress}" SortMemberPath="ModbusAddress" IsReadOnly="True" Width="110" />
                            <DataGridTextColumn Header="{DynamicResource ColumnPlcAddress}" Binding="{Binding PlcAddress, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            <DataGridTemplateColumn Header="{DynamicResource ColumnDisplayType}" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayType, Converter={StaticResource DisplayTypeTextConverter}}"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0"
                                                       Visibility="{Binding IsBool, Converter={StaticResource BoolVisibilityConverter}}" />
                                            <ComboBox ItemsSource="{Binding AvailableDisplayTypes}"
                                                      SelectedItem="{Binding DisplayType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Visibility="{Binding IsRegister, Converter={StaticResource BoolVisibilityConverter}}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource DisplayTypeTextConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource ColumnComment}" Binding="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

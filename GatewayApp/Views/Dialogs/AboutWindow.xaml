<Window x:Class="GatewayApp.Views.Dialogs.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AboutTitle}"
        Width="700"
        Height="480"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Background="#ebebeb">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="14">
            <Button Content="{DynamicResource CommonClose}"
                    Width="88"
                    IsDefault="True"
                    Click="Close_Click" />
        </StackPanel>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border BorderBrush="#c8c8c8"
                    BorderThickness="1"
                    Background="#f8f8f8"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Factory I/O Gateway"
                               Foreground="#1f1f1f"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock x:Name="VersionTextBlock"
                               Foreground="#1f1f1f"
                               Margin="0,6,0,0" />
                    <TextBlock Foreground="#1f1f1f"
                               Margin="0,2,0,0"
                               Text="Company: FA Labo" />
                    <TextBlock Foreground="#1f1f1f"
                               Margin="0,2,0,0"
                               Text="Copyright: FA Labo(fa_yoshinobu)" />
                    <TextBlock Foreground="#1f1f1f"
                               Margin="0,8,0,0">
                        <Run Text="GitHub: " />
                        <Hyperlink NavigateUri="https://github.com/fa-yoshinobu/factoryio-slmp-hostlink-gateway"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            https://github.com/fa-yoshinobu/factoryio-slmp-hostlink-gateway
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <GroupBox Grid.Row="2"
                      Header="Libraries"
                      Foreground="#1f1f1f"
                      BorderBrush="#c8c8c8">
                <ListView x:Name="LibrariesListView"
                          Margin="8"
                          Background="#ffffff"
                          BorderBrush="#d0d0d0"
                          Focusable="False"
                          SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Setter Property="Foreground" Value="#1f1f1f" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Library"
                                            Width="220"
                                            DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Version"
                                            Width="110"
                                            DisplayMemberBinding="{Binding Version}" />
                            <GridViewColumn Header="Notes"
                                            Width="300"
                                            DisplayMemberBinding="{Binding Notes}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>

<Window x:Class="GatewayApp.Views.Dialogs.CsvImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GatewayApp.Converters"
        Title="{DynamicResource CsvPreviewTitle}"
        Width="780"
        Height="520"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:DisplayTypeTextConverter x:Key="DisplayTypeTextConverter" />
    </Window.Resources>
    <DockPanel Background="#ebebeb">
        <TextBlock DockPanel.Dock="Top"
                   x:Name="SummaryText"
                   Margin="14,12,14,8"
                   Foreground="#222"
                   FontWeight="Bold" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14,10,14,14">
            <Button Content="{DynamicResource CommonCancel}" Width="96" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="{DynamicResource CommonApply}" Width="96" IsDefault="True" Click="Apply_Click" />
        </StackPanel>
        <DataGrid x:Name="PreviewGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="14,0"
                  LoadingRow="PreviewGrid_LoadingRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource ColumnAction}" Binding="{Binding ActionText}" Width="90" />
                <DataGridTextColumn Header="Modbus" Binding="{Binding ModbusLabel}" Width="120" />
                <DataGridTextColumn Header="{DynamicResource ColumnName}" Binding="{Binding Name}" Width="2*" />
                <DataGridTemplateColumn Header="{DynamicResource ColumnDisplayType}" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayType, Converter={StaticResource DisplayTypeTextConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource ColumnExistingPlc}" Binding="{Binding ExistingPlcAddress}" Width="120" />
                <DataGridTextColumn Header="{DynamicResource ColumnReason}" Binding="{Binding Reason}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
